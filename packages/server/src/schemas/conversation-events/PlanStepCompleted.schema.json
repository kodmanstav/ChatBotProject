{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanStepCompleted",
  "type": "object",
  "required": ["eventType", "conversationId", "timestamp", "payload"],
  "properties": {
    "eventType": { "const": "PlanStepCompleted" },
    "conversationId": { "type": "string" },
    "timestamp": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["step", "status"],
      "properties": {
        "step": { "type": "integer" },
        "status": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
