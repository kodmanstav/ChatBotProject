{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanFailed",
  "type": "object",
  "required": ["eventType", "conversationId", "timestamp", "payload"],
  "properties": {
    "eventType": { "const": "PlanFailed" },
    "conversationId": { "type": "string" },
    "timestamp": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["failedStep", "reason"],
      "properties": {
        "failedStep": { "type": "integer" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
