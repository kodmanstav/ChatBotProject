{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanGenerated",
  "type": "object",
  "required": ["eventType", "conversationId", "timestamp", "payload"],
  "properties": {
    "eventType": { "const": "PlanGenerated" },
    "conversationId": { "type": "string" },
    "timestamp": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["plan"],
      "properties": {
        "plan": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step", "tool", "parameters"],
            "properties": {
              "step": { "type": "integer" },
              "tool": { "type": "string" },
              "parameters": { "type": "object" }
            }
          }
        },
        "final_answer_synthesis_required": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
