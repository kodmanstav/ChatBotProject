{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanCompleted",
  "type": "object",
  "required": ["eventType", "conversationId", "timestamp", "payload"],
  "properties": {
    "eventType": { "const": "PlanCompleted" },
    "conversationId": { "type": "string" },
    "timestamp": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["completedSteps", "results"],
      "properties": {
        "completedSteps": { "type": "integer" },
        "results": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
